-- ==================== Blox Fruits Fruits M1 Fast Attack GUI ====================
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("Fruits Fast Attack", "Ocean")  -- 你可以改顏色: Ocean, Sentinel, Midnight 等

local Tab = Window:NewTab("Fast Attack")
local Section = Tab:NewSection("Fruits M1 Fast Attack")

-- ==================== 設定變數 ====================
_G.Config = _G.Config or {}
_G.Config.FastAttack = _G.Config.FastAttack or {
    FruitsM1 = false,
    FruitsM1Delay = 0.1,   -- 攻擊間隔 (越小越快，但太小可能被檢測)
    SelectFruits = "Kitsune"  -- 預設水果
}

local FruitsList = {
    "Kitsune", "Control", "Dragon", "Gas", "Pain",
    "Blade", "T-Rex", "Yeti", "Tiger"
}

-- ==================== 主要功能 ====================
local function GetFruitsRemote()
    local LocalPlayer = game.Players.LocalPlayer
    local char = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local tool = nil

    -- 檢查角色身上
    if char then
        for _, fruitName in ipairs(FruitsList) do
            if _G.Config.FastAttack.SelectFruits == fruitName then
                tool = char:FindFirstChild(fruitName .. "-" .. fruitName)
                break
            end
        end
        if tool then
            return tool:FindFirstChild("LeftClickRemote", true)
        end
    end

    -- 檢查背包
    if backpack then
        for _, fruitName in ipairs(FruitsList) do
            if _G.Config.FastAttack.SelectFruits == fruitName then
                tool = backpack:FindFirstChild(fruitName .. "-" .. fruitName)
                break
            end
        end
        if tool then
            return tool:FindFirstChild("LeftClickRemote", true)
        end
    end
    return nil
end

-- ==================== Fast Attack Loop ====================
local attackConnection = nil

local function StartFastAttack()
    if attackConnection then return end

    attackConnection = task.spawn(function()
        while _G.Config.FastAttack.FruitsM1 do
            task.wait(_G.Config.FastAttack.FruitsM1Delay)
            
            local LocalPlayer = game.Players.LocalPlayer
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local remote = GetFruitsRemote()

            if char and hrp and remote then
                local direction = -hrp.CFrame.UpVector
                remote:FireServer(direction, 2, true)
            end
        end
    end)
end

local function StopFastAttack()
    _G.Config.FastAttack.FruitsM1 = false
    if attackConnection then
        task.cancel(attackConnection)
        attackConnection = nil
    end
end

-- ==================== GUI 元件 ====================
Section:NewToggle("開啟 Fruits M1 Fast Attack", "啟用後會自動快速點擊水果左鍵", function(state)
    _G.Config.FastAttack.FruitsM1 = state
    if state then
        StartFastAttack()
    else
        StopFastAttack()
    end
end)

Section:NewSlider("攻擊延遲 (秒)", "數值越小攻擊越快 (建議 0.05 ~ 0.2)", 100, 0, 1, function(value)
    _G.Config.FastAttack.FruitsM1Delay = value
end, true)  -- true = 顯示小數點

Section:NewDropdown("選擇水果", "選擇你要快速攻擊的水果", FruitsList, function(selected)
    _G.Config.FastAttack.SelectFruits = selected
    print("已切換水果: " .. selected)
end)

-- 額外小功能：一鍵停止
Section:NewButton("強制停止 Fast Attack", "立即關閉攻擊", function()
    StopFastAttack()
    Library:Notify("Fast Attack 已停止", "所有 Fruits M1 攻擊已關閉", 3)
end)

-- ==================== 通知與結束 ====================
Library:Notify("腳本載入成功", "Fruits Fast Attack GUI 已準備好使用！", 5)

print("✅ Fruits M1 Fast Attack GUI 已載入完成！")
