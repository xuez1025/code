fill.BackgroundColor3 = Color3.fromRGB(255,200,0)
fill.BorderSizePixel = 0
fill.Parent = slider

local dragging = false
local MAX_DISTANCE = 1000

slider.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        frame.Draggable = false
    end
end)

slider.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
        frame.Draggable = true
    end
end)

slider.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local mouseX = input.Position.X - slider.AbsolutePosition.X
        mouseX = math.clamp(mouseX, 0, slider.AbsoluteSize.X)
        local distance = (mouseX / slider.AbsoluteSize.X) * MAX_DISTANCE
        Settings.Distance = math.floor(distance)
        label.Text = "攻擊距離: "..Settings.Distance.." 米"
        inputBox.Text = tostring(Settings.Distance)
        fill.Size = UDim2.new(mouseX / slider.AbsoluteSize.X, 0, 1, 0)
    end
end)

inputBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        local val = tonumber(inputBox.Text)
        if val then
            local distance = math.clamp(val, 0, MAX_DISTANCE)
            Settings.Distance = math.floor(distance)
            inputBox.Text = tostring(Settings.Distance)
            label.Text = "攻擊距離: "..Settings.Distance.." 米"
            fill.Size = UDim2.new(distance / MAX_DISTANCE, 0, 1, 0)
        else
            inputBox.Text = tostring(Settings.Distance)
        end
    end
end)

-- ====================== 攻擊邏輯控制 ======================

local autoConnection
local manualConnection

local function startAuto()
    if autoConnection then return end
    autoConnection = RunService.Heartbeat:Connect(function()
        if not Settings.AutoClick then return end
        PerformAttack()
        task.wait(Settings.AttackInterval)  -- 更精準的間隔控制
    end)
end

local function stopAuto()
    if autoConnection then
        autoConnection:Disconnect()
        autoConnection = nil
    end
end

local function startManual()
    if manualConnection then return end
    manualConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if Settings.AutoClick then return end  -- 只在手動模式觸發
        
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            PerformAttack()
        end
    end)
end

local function stopManual()
    if manualConnection then
        manualConnection:Disconnect()
        manualConnection = nil
    end
end

-- 開關按鈕事件
toggleBtn.MouseButton1Click:Connect(function()
    Settings.AutoClick = not Settings.AutoClick
    toggleBtn.Text = "自動攻擊: " .. (Settings.AutoClick and "開" or "關")
    
    if Settings.AutoClick then
        stopManual()
        startAuto()
    else
        stopAuto()
        startManual()
    end
end)

-- 初始狀態
if Settings.AutoClick then
    startAuto()
else
    startManual()
end

-- 角色重生/離開時清理
Player.CharacterRemoving:Connect(function()
    stopAuto()
    stopManual()
end)

-- 腳本結束時也清理（可選）
