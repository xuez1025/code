local Player = Players.LocalPlayer
local Net = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")
local RegisterAttack = Net:WaitForChild("RE/RegisterAttack")
local RegisterHit = Net:WaitForChild("RE/RegisterHit")
local EnemiesFolder = workspace:WaitForChild("Enemies")
local CharactersFolder = workspace:WaitForChild("Characters")

local Settings = {
    AutoClick = true,
    Distance = 0,
    AttackInterval = 0.01,
    MaxTargets = 20
}

local function IsAlive(char)
    local hum = char:FindFirstChild("Humanoid")
    return hum and hum.Health > 0
end

-- 取得範圍內有效目標
local function GetValidTargets(root)
    local targets = {}
    for _, folder in ipairs({EnemiesFolder, CharactersFolder}) do
        for _, obj in ipairs(folder:GetChildren()) do
            if obj ~= Player.Character then
                local head = obj:FindFirstChild("Head")
                if head and IsAlive(obj) then
                    local dist = (head.Position - root.Position).Magnitude
                    if dist <= Settings.Distance then
                        table.insert(targets, {obj, head})
                        if #targets >= Settings.MaxTargets then
                            return targets
                        end
                    end
                end
            end
        end
    end
    return targets
end

-- 執行一次攻擊
local function PerformAttack()
    local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local targets = GetValidTargets(root)
    if #targets > 0 then
        RegisterAttack:FireServer(0)
        RegisterHit:FireServer(targets[1][2], targets)  -- 第一個作為主要目標，送全部
    end
end

